{
	"id": "api_extract_uri",
	"description": "Tests URI extraction API",
	"tags": ["contract", "api"],
	"input": {
		"kind": "uri",
		"uri": "pdf/fake_memo.pdf"
	},
	"assertions": [
		{
			"type": "equals",
			"field": "results[0].mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "results[0].content",
			"value": 10
		},
		{
			"type": "contains_any",
			"field": "results[0].content",
			"values": ["May 5, 2023", "Mallori"]
		}
	],
	"skip": {
		"languages": ["wasm"],
		"reason": "WASM cannot access filesystem; use bytes input with file content instead"
	},
	"category": "contract",
	"call": "extract"
}
