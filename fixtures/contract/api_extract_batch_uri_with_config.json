{
	"id": "api_extract_batch_uri_with_config",
	"description": "Tests batch URI extraction with per-input config (extract_batch)",
	"tags": ["contract", "api", "batch", "input_config"],
	"call": "extract_batch",
	"input": {
		"inputs": [
			{
				"kind": "uri",
				"uri": "pdf/fake_memo.pdf",
				"config": {
					"output_format": "markdown"
				}
			}
		]
	},
	"assertions": [
		{
			"type": "equals",
			"field": "results[0].mime_type",
			"value": "application/pdf"
		},
		{
			"type": "min_length",
			"field": "results[0].content",
			"value": 10
		},
		{
			"type": "equals",
			"field": "results[0].metadata.output_format",
			"value": "markdown"
		}
	],
	"skip": {
		"languages": ["wasm"],
		"reason": "WASM cannot access filesystem; use bytes input with file content instead"
	}
}
