{
	"id": "code_javascript_basic",
	"category": "code",
	"tags": ["code", "javascript", "tree-sitter"],
	"description": "Smoke test: JavaScript source code file extraction",
	"document": {
		"path": "code/app.js",
		"media_type": "text/x-source-code"
	},
	"extraction": {
		"config": {}
	},
	"assertions": {
		"expected_mime": "text/x-source-code",
		"min_content_length": 10,
		"content_contains_all": ["class Application", "export function", "import"]
	},
	"skip": {
		"requires_feature": ["tree-sitter"]
	}
}
