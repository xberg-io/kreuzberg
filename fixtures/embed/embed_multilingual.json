{
	"id": "embed_multilingual",
	"description": "Standalone embedding with multilingual preset for non-English text",
	"tags": ["embed"],
	"embed": {
		"texts": ["Bonjour le monde", "Hallo Welt", "¡Hola Mundo!"],
		"config": {
			"model": { "type": "preset", "name": "multilingual" },
			"normalize": true
		}
	},
	"assertions": {
		"embed": {
			"count": 3,
			"dimensions": 768,
			"no_nan": true,
			"no_inf": true,
			"non_zero": true
		}
	},
	"skip": {
		"requires_feature": ["embeddings"],
		"skip_on_platform": ["x86_64-pc-windows-msvc"],
		"notes": "Embeddings not supported on Windows MSVC"
	}
}
