{
  "id": "dedup_basic",
  "category": "text_utils",
  "description": "Deduplicate repeated lines",
  "tags": ["text_utils", "deduplication"],
  "call": "dedup_text",
  "input": {
    "texts": ["line1", "line1", "line2", "line2", "line3"]
  },
  "assertions": [
    {
      "type": "not_error"
    },
    {
      "type": "contains",
      "field": "result",
      "value": "line1"
    }
  ]
}
