# =============================================================================
# .dockerignore — Docker builds only need Cargo.toml, Cargo.lock, and crates/
# Exclude everything else to minimize context and speed up builds.
# =============================================================================

# Start by ignoring everything
*

# Allow only what Docker builds need
!Cargo.toml
!Cargo.lock
!kreuzberg/crates/kreuzberg/
!kreuzberg/crates/kreuzberg-cli/
!kreuzberg/crates/kreuzberg-tesseract/
!kreuzberg/crates/kreuzberg-paddle-ocr/
!kreuzberg/crates/kreuzberg-pdfium-render/
!kreuzberg/crates/kreuzberg-ffi/
!kreuzberg/crates/kreuzberg-py/
!kreuzberg/crates/kreuzberg-node/
!kreuzberg/crates/kreuzberg-wasm/
!kreuzberg/packages/elixir/native/kreuzberg_rustler/
!kreuzberg/docker/

# Re-exclude build artifacts inside allowed dirs
**/target/
**/.git/
**/node_modules/
**/__pycache__/
**/*.pyc
**/*.so
**/*.dylib
**/*.dll
**/*.node
