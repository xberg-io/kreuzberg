{
	"id": "config_email_msg_fallback_codepage",
	"category": "contract",
	"tags": ["contract", "config", "email"],
	"description": "Tests MSG extraction with custom fallback codepage for Cyrillic",
	"document": {
		"path": "email/fake_email.msg",
		"media_type": "application/vnd.ms-outlook"
	},
	"extraction": {
		"config": {
			"email": {
				"msg_fallback_codepage": 1251
			}
		}
	},
	"assertions": {
		"expected_mime": "application/vnd.ms-outlook",
		"min_content_length": 10
	}
}
