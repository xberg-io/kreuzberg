{
	"id": "api_batch_file_with_configs_sync",
	"description": "Tests sync batch file extraction with per-file configs (batch_extract_files_sync with file_configs parameter)",
	"tags": ["contract", "api", "batch", "file_config"],
	"document": {
		"path": "pdf/fake_memo.pdf"
	},
	"extraction": {
		"method": "batch_sync",
		"input_type": "file",
		"config": {},
		"file_configs": [{ "output_format": "markdown" }]
	},
	"assertions": {
		"expected_mime": "application/pdf",
		"min_content_length": 10,
		"output_format_is": "markdown"
	}
}
