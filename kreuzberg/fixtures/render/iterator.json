{
	"id": "render_iterator",
	"category": "render",
	"tags": ["render", "pdf", "iterator"],
	"description": "Iterate all PDF pages as PNG images",
	"document": {
		"path": "pdf/tiny.pdf",
		"media_type": "application/pdf"
	},
	"render": {
		"mode": "iterator",
		"dpi": 150
	},
	"assertions": {
		"render": {
			"is_png": true,
			"page_count_gte": 1
		}
	}
}
