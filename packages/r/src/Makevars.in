CARGO_BUILD_ARGS = --release
STATLIB = ./rust/target/release/libkreuzberg_r.a
HEIF_LIBS = $(shell pkg-config --libs libheif 2>/dev/null || echo "-lheif")

# Add rpath so the R .so extension can locate transitively-linked ORT shared libraries
# @loader_path (macOS) and $ORIGIN (Linux) resolve to the directory containing the .so
RPATH_MACOS = -Wl,-rpath,@loader_path
RPATH_LINUX = -Wl,-rpath,$$ORIGIN
RPATH_FLAGS = $(if $(filter Darwin,$(shell uname)),$(RPATH_MACOS),$(RPATH_LINUX))

PKG_LIBS = -L./rust/target/release -lkreuzberg_r $(HEIF_LIBS) $(LAPACK_LIBS) $(BLAS_LIBS) $(FLIBS) $(RPATH_FLAGS)

all: $(SHLIB)

$(STATLIB):
	cargo build --manifest-path ./rust/Cargo.toml $(CARGO_BUILD_ARGS)

$(SHLIB): $(STATLIB)

binary:
	cd .. && R CMD INSTALL --build .

clean:
	rm -f $(SHLIB) $(STATLIB)
	cargo clean --manifest-path ./rust/Cargo.toml
