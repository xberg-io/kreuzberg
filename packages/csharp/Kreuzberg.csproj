<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <RootNamespace>Kreuzberg</RootNamespace>
    <PackageId>Kreuzberg</PackageId>
    <Version>4.10.0-rc.15</Version>
    <Description>High-performance document intelligence library</Description>
    <PackageLicenseExpression>Elastic-2.0</PackageLicenseExpression>
    <RepositoryUrl>https://github.com/kreuzberg-dev/kreuzberg</RepositoryUrl>
    <Authors>Na'aman Hirschfeld</Authors>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
  </PropertyGroup>

  <ItemGroup>
    <!-- Copy native libraries to runtimes/{rid}/native/ in the output directory -->
    <Content Include="Kreuzberg/runtimes/osx-arm64/native/libkreuzberg_ffi.dylib" CopyToOutputDirectory="PreserveNewest" Link="runtimes/osx-arm64/native/libkreuzberg_ffi.dylib" />
    <Content Include="Kreuzberg/runtimes/osx-x64/native/libkreuzberg_ffi.dylib" Condition="Exists('Kreuzberg/runtimes/osx-x64/native/libkreuzberg_ffi.dylib')" CopyToOutputDirectory="PreserveNewest" Link="runtimes/osx-x64/native/libkreuzberg_ffi.dylib" />
    <Content Include="Kreuzberg/runtimes/osx-arm64/native/libpdfium.dylib" CopyToOutputDirectory="PreserveNewest" Link="runtimes/osx-arm64/native/libpdfium.dylib" />
    <Content Include="Kreuzberg/runtimes/osx-x64/native/libpdfium.dylib" Condition="Exists('Kreuzberg/runtimes/osx-x64/native/libpdfium.dylib')" CopyToOutputDirectory="PreserveNewest" Link="runtimes/osx-x64/native/libpdfium.dylib" />
    <!-- Also copy pdfium to the root output so dlopen("libpdfium.dylib") resolves correctly.
         The kreuzberg_ffi native library uses dlopen at runtime to load pdfium, and macOS's
         dynamic linker searches the directory containing the loading library first. -->
    <Content Include="Kreuzberg/runtimes/osx-arm64/native/libpdfium.dylib" CopyToOutputDirectory="PreserveNewest" Link="libpdfium.dylib" />
    <Content Include="Kreuzberg/runtimes/osx-x64/native/libpdfium.dylib" Condition="Exists('Kreuzberg/runtimes/osx-x64/native/libpdfium.dylib')" CopyToOutputDirectory="PreserveNewest" Link="libpdfium.dylib" />
  </ItemGroup>
</Project>
