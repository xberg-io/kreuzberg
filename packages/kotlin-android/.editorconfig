# Generated by alef. Do not edit by hand.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.kt]
indent_style = space
indent_size = 4
# Java packages derived from hyphenated GitHub orgs (e.g. `kreuzberg-dev` →
# `com.github.kreuzberg_dev`) carry underscores; allow them for the
# co-located Java facade and its Kotlin wrappers.
ktlint_standard_package-name = disabled

[*.gradle.kts]
indent_style = space
indent_size = 4

[*.{xml,pro,gitignore}]
indent_style = space
indent_size = 2
